{
  "name": "nodejs-demo-app",
  "version": "1.0.0",
  "description": "A demo Node.js app for CI/CD pipeline demonstration",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --forceExit",
    "test:ci": "jest --coverage --ci --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov"],
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["nodejs", "express", "docker", "cicd"],
  "license": "MIT"
}
